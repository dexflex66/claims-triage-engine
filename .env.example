# Core runtime
APP_ENV=dev
DATABASE_URL=sqlite:///./payer_proof_claims.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
OIDC_AUDIENCE=payer-proof-claims
OIDC_REQUIRE_SIGNATURE=false
OIDC_ISSUER=
OIDC_JWKS_URL=
OIDC_JWKS_JSON=
OIDC_JWKS_CACHE_SECONDS=300
OIDC_JWKS_TIMEOUT_SECONDS=5
OIDC_ALLOW_INSECURE_JWKS=false

# US278 live connector
US278_BASE_URL=
US278_SUBMIT_PATH=/api/v1/prior-auth/submit
US278_STATUS_PATH_TEMPLATE=/api/v1/prior-auth/{external_ref}/status
US278_RECEIPT_PATH_TEMPLATE=/api/v1/prior-auth/{external_ref}/receipt
US278_AUTH_MODE=bearer_hmac
US278_API_TOKEN=
US278_HMAC_SECRET=
US278_HMAC_KEY_ID=
US278_ENFORCE_CONTRACT=true
US278_TIMEOUT_SECONDS=10
US278_MAX_RETRIES=3
US278_BACKOFF_SECONDS=0.5

# India preauth live connector
IN_PREAUTH_BASE_URL=
IN_PREAUTH_SUBMIT_PATH=/api/v1/preauth/submit
IN_PREAUTH_STATUS_PATH_TEMPLATE=/api/v1/preauth/{external_ref}/status
IN_PREAUTH_RECEIPT_PATH_TEMPLATE=/api/v1/preauth/{external_ref}/receipt
IN_PREAUTH_AUTH_MODE=bearer_hmac
IN_PREAUTH_API_TOKEN=
IN_PREAUTH_HMAC_SECRET=
IN_PREAUTH_HMAC_KEY_ID=
IN_PREAUTH_ENFORCE_CONTRACT=true
IN_PREAUTH_TIMEOUT_SECONDS=10
IN_PREAUTH_MAX_RETRIES=3
IN_PREAUTH_BACKOFF_SECONDS=0.5

# Optional payment rails
ACH_POST_BASE_URL=
ACH_POST_API_TOKEN=
ACH_POST_PATH=/api/v1/payments/ach
VCARD_POST_BASE_URL=
VCARD_POST_API_TOKEN=
VCARD_POST_PATH=/api/v1/payments/virtual-card
ERP_POST_BASE_URL=
ERP_POST_API_TOKEN=
ERP_POST_PATH=/api/v1/erp/payment-postings

# Security and controls
ALLOW_STUB_CONNECTORS=true
IP_ALLOWLIST_ENABLED=false
IP_ALLOWLIST_CIDRS=10.0.0.0/8,192.168.0.0/16
MTLS_REQUIRED=false
TLS_CLIENT_CA_CERT_PATH=
TLS_SERVER_CERT_PATH=
TLS_SERVER_KEY_PATH=
KEY_ROTATION_ENFORCED=false
US278_ACTIVE_KEY_ID=
US278_ALLOWED_KEY_IDS=

# Logging / observability
LOG_JSON=true
LOG_LEVEL=INFO

# Compliance gate toggles (required true before go-live)
LEGAL_APPROVED=false
SECURITY_APPROVED=false
COMPLIANCE_APPROVED=false
DPA_SIGNED=false
BAA_SIGNED=false
HIPAA_RISK_ASSESSMENT_COMPLETE=false
